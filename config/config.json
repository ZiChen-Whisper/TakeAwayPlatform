/*
 * ============================================================
 * 这是项目的配置文件，使用 JSON 格式（JavaScript Object Notation）
 * JSON 是目前最流行的数据交换格式，结构清晰易读
 * 
 * JSON 语法要点（小白必看）：
 * 1. 整个文件用一对大括号 {} 包裹，表示一个"对象"
 * 2. 对象里面是"键值对"，格式为 "键名": 值
 * 3. 字符串必须用双引号 "" 包住，数字不需要引号
 * 4. 键值对之间用逗号 , 分隔
 * 5. 对象可以嵌套（对象里面还可以有对象）
 * 6. 值可以是：字符串、数字、布尔值(true/false)、对象、数组、null
 * ============================================================
 */
{
    // ---------- 数据库配置 ----------
    // "database" 是一个键，它的值是一个嵌套的对象（用 {} 表示）
    "database": 
    {
        // 数据库所在的主机地址
        // "127.0.0.1" 是一个特殊的 IP 地址，表示"本机"（自己的电脑）
        // 意思是数据库就装在本机，程序直接连本机的数据库
        "host": "127.0.0.1",

        // 数据库的端口号
        // 端口就像一个"门牌号"，电脑上每个网络服务都有唯一的端口号
        // 3306 是 MySQL 数据库的默认端口（行业标准）
        // 注意：这里用 MySQL X Protocol 时端口是 33060（不同协议端口不同）
        "port": 3306,

        // 数据库的登录用户名
        // "root" 是 MySQL 的超级管理员账户，拥有最高权限
        // 实际生产环境不建议用 root，应该创建专门的受限账户
        "user": "root",

        // 数据库的登录密码
        // 这里是明文密码，实际生产环境应该加密存储或使用环境变量
        "password": "123",

        // 要连接的数据库名字
        // MySQL 里可以创建多个数据库（Database），这里指定使用哪个
        // Schema 和 Database 在 MySQL 里是同一个概念
        "name": "TakeAwayDatabase",

        // 数据库连接池的大小
        // 连接池是预先创建好的数据库连接，用的时候直接取，不用每次新建
        // 池子里有 10 个连接，可以同时处理最多 10 个数据库请求
        // 类似共享单车：提前准备好一批"车"，用户随取随用
        "pool_size": 10
    },

    // ---------- 服务器配置 ----------
    "server": 
    {
        // HTTP 服务器监听的端口号
        // 客户端（浏览器、App）通过这个端口来访问我们的服务
        // 比如访问 http://localhost:9090/menu 就是连到这个端口
        // 9090 是自定义端口，不是标准端口，避免和系统服务冲突
        "port": 9090,

        // 请求超时时间（单位：秒）
        // 如果客户端 10 秒内没有响应，服务器就断开连接
        // 防止"僵尸连接"一直占用资源
        "timeout": 10,

        // 线程池中工作线程的数量
        // 线程是 CPU 调度的最小单位，多个线程可以"同时"处理多个请求
        // 8 个线程意味着最多同时处理 8 个客户端请求
        // 线程数不是越多越好：太多会增加上下文切换开销，太少会响应慢
        "thread_pool_size": 8
    }
}